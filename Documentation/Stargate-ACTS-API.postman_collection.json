		{
			"name": "3 — Query & Verify",
			"description": "GET endpoints — verify data integrity after creates.",
			"item": [
				{
					"name": "Get All People",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns people array', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    pm.expect(json.people).to.be.an('array');",
									"    pm.expect(json.people.length).to.be.at.least(4);",
									"});",
									"",
									"pm.test('Chris Hadfield has no astronaut detail (Rule 2)', () => {",
									"    const json = pm.response.json();",
									"    const chris = json.people.find(p => p.name === 'Chris Hadfield');",
									"    pm.expect(chris).to.exist;",
									"    pm.expect(chris.currentRank).to.be.null;",
									"    pm.expect(chris.currentDutyTitle).to.be.null;",
									"});",
									"",
									"pm.test('Sally Ride shows as RETIRED', () => {",
									"    const json = pm.response.json();",
									"    const sally = json.people.find(p => p.name === 'Sally Ride');",
									"    pm.expect(sally).to.exist;",
									"    pm.expect(sally.currentDutyTitle).to.eql('RETIRED');",
									"    pm.expect(sally.careerEndDate).to.not.be.null;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/Person",
							"host": ["{{baseUrl}}"],
							"path": ["Person"]
						}
					}
