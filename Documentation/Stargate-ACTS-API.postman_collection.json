									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    pm.expect(json.person.name).to.eql('Neil Armstrong');",
									"    pm.expect(json.person.currentRank).to.eql('Brigadier General');",
									"    pm.expect(json.person.currentDutyTitle).to.eql('Mission Specialist');",
									"    pm.expect(json.person.careerEndDate).to.be.null;",
									"});"
								],
