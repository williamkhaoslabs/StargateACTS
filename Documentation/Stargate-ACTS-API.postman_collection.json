				{
					"name": "Get Duties — Neil Armstrong",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns person + duties', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    pm.expect(json.person).to.exist;",
									"    pm.expect(json.astronautDuties).to.be.an('array');",
									"    pm.expect(json.astronautDuties.length).to.eql(2);",
									"});",
									"",
									"pm.test('Previous duty has end date (Rule 5)', () => {",
									"    const json = pm.response.json();",
									"    // Duties sorted newest-first",
									"    const currentDuty = json.astronautDuties[0];",
									"    const previousDuty = json.astronautDuties[1];",
									"",
									"    // Current duty has no end date (Rule 4)",
									"    pm.expect(currentDuty.dutyEndDate).to.be.null;",
									"    pm.expect(currentDuty.dutyTitle).to.eql('Mission Specialist');",
									"",
									"    // Previous duty end date = new start - 1 day",
									"    pm.expect(previousDuty.dutyEndDate).to.not.be.null;",
									"    pm.expect(previousDuty.dutyEndDate).to.include('2024-06-30');",
									"    pm.expect(previousDuty.dutyTitle).to.eql('Commander');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
